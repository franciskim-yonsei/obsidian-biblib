+  wchar_t value[8];
+  DWORD len = GetEnvironmentVariableW(
+      L"LEAN_TERMINAL_CONPTY_PASSTHROUGH",
+      value,
+      sizeof(value) / sizeof(value[0]));
+  return len > 0 && value[0] == L'1';
+}
